<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PizzAPP.CatalogoPage"
             Title="CatalogoPage">
    <ScrollView>

        <HorizontalStackLayout
            HeightRequest="350">


            <Image x:Name="imgPizza"
                   HeightRequest="300"/>


            <VerticalStackLayout>
                <Label x:Name="lblNome"
                       FontSize="12"/>
                <Label x:Name="lblPrezzo"/>
                <Label x:Name="lblIngredienti"/>
            </VerticalStackLayout>
        </HorizontalStackLayout>
        
    </ScrollView>

</ContentPage>