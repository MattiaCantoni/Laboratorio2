<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AppDiario.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Spacing="20"
            Padding="20">

            <Label
                Text="Il mio diario"
                FontSize="24"
                HorizontalOptions="Center"
                FontAttributes="Bold"/>

            <Entry
                x:Name="entTitolo"
                Placeholder="Inserisci titolo"/>

            <Entry
                x:Name="entTesto"
                Placeholder="Inserisci testo"/>

            <Button
                x:Name="btnSalva"
                Text="Salva nota"
                FontSize="12"
                BackgroundColor="Green"
                TextColor="White"
                Clicked="btnSalva_Clicked"/>

            <Button
                x:Name="btnLeggi"
                Text="Leggi le note"
                BackgroundColor="Gray"
                TextColor="White"
                Clicked="btnLeggi_Clicked"/>

            <BoxView
                HeightRequest="1"
                Color="Silver"/>

            <Label
                Text="Note salvate nel file:"
                FontAttributes="Italic"/>

            <Editor
                x:Name="editDisplay"
                HeightRequest="300"
                IsReadOnly="True"
                BackgroundColor="GhostWhite"/>



        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
